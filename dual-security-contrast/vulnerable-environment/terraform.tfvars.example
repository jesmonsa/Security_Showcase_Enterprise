# ========================================
# AMBIENTE VULNERABLE - CONFIGURACIÓN
# ⚠️  ADVERTENCIA: ESTE AMBIENTE ES DELIBERADAMENTE INSEGURO
# ========================================

# ========================================
# ACKNOWLEDGMENT - REQUERIDO
# ========================================
acknowledge_insecure_deployment = true
demo_disclaimer_accepted = true

# ========================================
# OCI AUTHENTICATION
# ========================================
tenancy_ocid     = "ocid1.tenancy.oc1..example"
user_ocid        = "ocid1.user.oc1..example"
fingerprint      = "xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx"
private_key_path = "/home/jesmonsa/.oci/oci_api_key.pem"

# ========================================
# REGIONAL CONFIGURATION
# ========================================
region = "us-ashburn-1"

# ========================================
# ENVIRONMENT CONFIGURATION
# ========================================
environment = "vulnerable"

# ========================================
# NETWORK CONFIGURATION - INSEGURA
# ========================================
vcn_cidr_block = "10.50.0.0/16"  # Rango diferente para evitar conflictos

# ========================================
# COMPUTE CONFIGURATION - DESPROTEGIDO
# ========================================
instance_shape = "VM.Standard.E4.Flex"
instance_count = 2

# ========================================
# DATABASE CONFIGURATION - ORACLE 23ai VULNERABLE
# ========================================
db_admin_password = "Welcome123!"  # ⚠️  PASSWORD DÉBIL INTENCIONAL
enable_public_database_access = true  # ⚠️  CRÍTICO: Base de datos pública

# ========================================
# VULNERABILITY SETTINGS - PARA DEMO
# ========================================
install_vulnerable_software = true    # Instala software con vulnerabilidades conocidas
enable_weak_ssl_ciphers = true       # Habilita cifrados SSL débiles
disable_os_updates = true            # ⚠️  Deshabilita actualizaciones de seguridad

# ========================================
# MONITORING - MÍNIMO
# ========================================
enable_basic_logging = true          # Solo logging básico
disable_security_monitoring = true   # ⚠️  Sin monitoreo de seguridad

# ========================================
# DEMO CONFIGURATION
# ========================================
demo_mode = true                     # Habilita vulnerabilidades adicionales para demo

# ========================================
# COST OPTIMIZATION (OPCIONAL)
# ========================================
use_always_free_resources = false   # Cambiar a true para usar recursos Always Free

# ========================================
# 🚨 ADVERTENCIAS CRÍTICAS DE SEGURIDAD 🚨
# ========================================

# Esta configuración implementa DELIBERADAMENTE las siguientes VULNERABILIDADES:

# 1. 🔐 IAM INSEGURO:
#    ❌ Todos los usuarios con permisos de administrador
#    ❌ Sin separación de compartments
#    ❌ Credenciales sin rotación
#    ❌ Sin MFA obligatorio

# 2. 🌐 RED COMPLETAMENTE EXPUESTA:
#    ❌ Base de datos en subnet pública (CRÍTICO)
#    ❌ Puerto Oracle 1521 abierto a internet
#    ❌ Security Lists permiten 0.0.0.0/0
#    ❌ Sin WAF, sin protección DDoS
#    ❌ Sin Flow Logs para monitoreo

# 3. 💻 COMPUTE SIN PROTECCIÓN:
#    ❌ SSH con password habilitado
#    ❌ Sin hardening de OS
#    ❌ Software vulnerable instalado
#    ❌ Sin cifrado de volúmenes
#    ❌ Sin Vulnerability Scanning

# 4. 🗄️  ORACLE 23ai SIN PROTECCIONES:
#    ❌ Database Firewall DESHABILITADO
#    ❌ Data Safe DESHABILITADO
#    ❌ Password débil (Welcome123!)
#    ❌ Acceso público directo
#    ❌ Sin cifrado con customer keys
#    ❌ Backups sin cifrado adicional

# 5. 📱 APLICACIÓN VULNERABLE:
#    ❌ Vulnerabilidades OWASP Top 10
#    ❌ SQL Injection habilitado
#    ❌ XSS sin protección
#    ❌ Path Traversal permitido
#    ❌ Secretos hardcodeados

# 6. 📊 MONITOREO DESHABILITADO:
#    ❌ Cloud Guard desactivado
#    ❌ Sin alertas de seguridad
#    ❌ Audit logging mínimo
#    ❌ Sin SIEM integration

